<%- include('partials/footer') %>

<% function getTransactionIcon(type) {
    const icons = {
        'deposit': 'arrow-down',
        'withdrawal': 'arrow-up', 
        'investment': 'chart-pie',
        'referral_bonus': 'gift',
        'buy': 'shopping-cart',
        'sell': 'dollar-sign'
    };
    return icons[type] || 'exchange-alt';
} %>