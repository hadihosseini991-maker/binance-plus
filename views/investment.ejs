}

.calculator-section {
    margin-bottom: 4rem;
}

.calculator-form {
    margin-bottom: 2rem;
}

.calculator-results {
    background: var(--accent-color);
    border-radius: 15px;
    padding: 2rem;
    border: 1px solid var(--border-color);
}

.calculator-results h4 {
    margin-bottom: 1.5rem;
    color: var(--text-primary);
}

.results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
