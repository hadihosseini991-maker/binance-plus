}

.investment-plan-card.featured:hover {
    transform: scale(1.05) translateY(-5px);
}

.plan-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--primary-color);
    color: #000;
    padding: 0.5rem 1.5rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 700;
}

.plan-header {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
}

.plan-header h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
}

.plan-amount {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--primary-color);
}

.plan-profit {
    text-align: center;
    margin-bottom: 2rem;
