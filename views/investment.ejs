    border-bottom: 1px solid var(--border-color);
}

.summary-item.total {
    color: var(--text-primary);
    font-weight: 600;
    font-size: 1.1rem;
}

.modal-footer {
    display: flex;
    gap: 1rem;
    padding: 1.5rem 2rem;
    border-top: 1px solid var(--border-color);
