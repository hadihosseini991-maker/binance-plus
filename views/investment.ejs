/* Responsive */
@media (max-width: 768px) {
    .investment-plans-grid {
        grid-template-columns: 1fr;
    }
    
    .investment-plan-card.featured {
        transform: none;
    }
    
    .investment-item {
        flex-direction: column;
        text-align: center;
        gap: 1rem;
    }
    
    .investment-meta {
        justify-content: center;
    }
    
    .results-grid {
        grid-template-columns: 1fr 1fr;
    }
    
    .modal-content {
        width: 95%;
        margin: 1rem;
    }
    
    .modal-footer {
        flex-direction: column;
    }
}

@media (max-width: 480px) {
    .page-header h1 {
        font-size: 2.5rem;
    }
    
    .investment-plan-card {
        padding: 2rem 1.5rem;
    }
    
    .plan-amount {
        font-size: 2rem;
    }
    
    .profit-percentage {
        font-size: 2rem;
    }
    
    .results-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Investment calculator
    const calcPlan = document.getElementById('calcPlan');
    const calcAmount = document.getElementById('calcAmount');
    const calcDays = document.getElementById('calcDays');
    const calculateBtn = document.getElementById('calculateBtn');
    const calculatorResults = document.getElementById('calculatorResults');
    
    // Set default amount to selected plan's amount
    calcPlan.addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const planAmount = selectedOption.dataset.amount;
        calcAmount.value = planAmount;
        calculateProfit();
    });
    
    // Calculate profit when inputs change
    [calcPlan, calcAmount, calcDays].forEach(input => {
        input.addEventListener('input', calculateProfit);
    });
    
    calculateBtn.addEventListener('click', calculateProfit);
    
    function calculateProfit() {
        const selectedOption = calcPlan.options[calcPlan.selectedIndex];
        const dailyProfitPercent = parseFloat(selectedOption.dataset.profit);
        const investmentAmount = parseFloat(calcAmount.value) || 0;
        const days = parseInt(calcDays.value) || 30;
        
        if (investmentAmount > 0 && days > 0) {
            const dailyProfit = (investmentAmount * dailyProfitPercent) / 100;
            const totalProfit = dailyProfit * days;
            const totalReturn = investmentAmount + totalProfit;
            const roi = (totalProfit / investmentAmount) * 100;
            
            document.getElementById('dailyProfit').textContent = '$' + dailyProfit.toFixed(2);
            document.getElementById('totalProfit').textContent = '$' + totalProfit.toFixed(2);
            document.getElementById('totalReturn').textContent = '$' + totalReturn.toFixed(2);
            document.getElementById('roiPercentage').textContent = roi.toFixed(1) + '%';
            
            calculatorResults.style.display = 'block';
        }
    }
    
    // Initialize calculator
    calculateProfit();
    
    // Investment modal
    const investButtons = document.querySelectorAll('.invest-btn');
    const investmentModal = document.getElementById('investmentModal');
    const cancelInvestment = document.getElementById('cancelInvestment');
    const confirmInvestment = document.getElementById('confirmInvestment');
    
    investButtons.forEach(button => {
        button.addEventListener('click', function() {
            const planId = this.dataset.planId;
            const planName = this.dataset.planName;
            const planAmount = this.dataset.planAmount;
            const dailyProfit = this.closest('.investment-plan-card').querySelector('.profit-percentage').textContent;
            
            document.getElementById('modalPlanName').textContent = planName;
            document.getElementById('modalPlanAmount').textContent = '$' + planAmount;
            document.getElementById('modalDailyProfit').textContent = dailyProfit;
            document.getElementById('selectedPlanId').value = planId;
            document.getElementById('selectedAmount').value = planAmount;
            
            // Calculate total profit
            const totalProfit = (parseFloat(planAmount) * parseFloat(dailyProfit) / 100 * 30).toFixed(2);
            document.getElementById('modalTotalProfit').textContent = '$' + totalProfit;
            
            investmentModal.classList.add('active');
        });
    });
    
    // Close modal
    cancelInvestment.addEventListener('click', function() {
        investmentModal.classList.remove('active');
    });
    
    document.querySelector('.modal-close').addEventListener('click', function() {
        investmentModal.classList.remove('active');
    });
    
    // Confirm investment
    confirmInvestment.addEventListener('click', function() {
        const form = document.getElementById('investmentForm');
        const formData = new FormData(form);
        
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }
        
        // Show loading state
        this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
        this.disabled = true;
        
        // Simulate API call
        setTimeout(() => {
            // In real app, you would submit to server
            alert('Investment successful! Your investment has been activated.');
            investmentModal.classList.remove('active');
            
            // Reset button
            this.innerHTML = '<i class="fas fa-check"></i> Confirm Investment';
            this.disabled = false;
            
            // Redirect to dashboard or refresh
            window.location.href = '/dashboard';
        }, 2000);
    });
    
    // FAQ functionality
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
        const question = item.querySelector('.faq-question');
        
        question.addEventListener('click', function() {
            // Close all other items
            faqItems.forEach(otherItem => {
                if (otherItem !== item) {
                    otherItem.classList.remove('active');
                }
            });
            
            // Toggle current item
            item.classList.toggle('active');
        });
    });
    
    // Close modal when clicking outside
    investmentModal.addEventListener('click', function(e) {
        if (e.target === this) {
            this.classList.remove('active');
        }
    });
});
</script>

