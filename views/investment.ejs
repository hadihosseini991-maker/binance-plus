<%- include('partials/header', { title: __('investment.title') }) %>

<div class="investment-container">
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <h1><%= __('investment.title') %></h1>
            <p>Choose from our premium investment plans and start earning daily profits</p>
        </div>

        <!-- Investment Plans Grid -->
        <div class="investment-plans-grid">
            <% investmentPlans.forEach((plan, index) => { %>
                <div class="investment-plan-card <%= index === 1 ? 'featured' : '' %>">
                    <% if (index === 1) { %>
                        <div class="plan-badge">Most Popular</div>
                    <% } %>
                    
                    <div class="plan-header">
                        <h3><%= plan.name %></h3>
                        <div class="plan-amount">$<%= plan.amount %></div>
                    </div>

                    <div class="plan-profit">
                        <div class="profit-percentage"><%= plan.dailyProfit %>%</div>
                        <div class="profit-label">Daily Profit</div>
                    </div>

                    <div class="plan-features">
                        <% plan.features.forEach(feature => { %>
                            <div class="feature-item">
                                <i class="fas fa-check"></i>
                                <span><%= feature %></span>
                            </div>
                        <% }) %>
                    </div>

                    <div class="plan-stats">
                        <div class="stat">
                            <div class="stat-value">30</div>
                            <div class="stat-label">Days</div>
                        </div>
                        <div class="stat">
                            <div class="stat-value">$<%= (plan.amount * plan.dailyProfit / 100 * 30).toFixed(0) %></div>
                            <div class="stat-label">Total Profit</div>
                        </div>
                    </div>

                    <div class="plan-action">
                        <% if (user) { %>
                            <button class="btn btn-primary btn-block invest-btn" 
                                    data-plan-id="<%= plan._id %>"
                                    data-plan-name="<%= plan.name %>"
                                    data-plan-amount="<%= plan.amount %>">
                                <i class="fas fa-chart-pie"></i>
                                Invest Now
                            </button>
                        <% } else { %>
                            <a href="/login" class="btn btn-outline btn-block">
                                <i class="fas fa-sign-in-alt"></i>
                                Login to Invest
                            </a>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Investment Calculator -->
        <div class="calculator-section">
            <div class="section-card">
                <div class="section-header">
                    <h2>Investment Calculator</h2>
                    <p>Calculate your potential earnings</p>
                </div>
                
                <div class="calculator-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="calcPlan">Select Plan</label>
                            <select id="calcPlan" class="form-control">
                                <% investmentPlans.forEach(plan => { %>
                                    <option value="<%= plan._id %>" 
                                            data-profit="<%= plan.dailyProfit %>"
                                            data-amount="<%= plan.amount %>">
                                        <%= plan.name %> - $<%= plan.amount %> (<%= plan.dailyProfit %>% daily)
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="calcAmount">Investment Amount ($)</label>
                            <input type="number" id="calcAmount" class="form-control" 
                                   min="0" step="1" value="300">
                        </div>
                        
                        <div class="form-group">
                            <label for="calcDays">Investment Period (Days)</label>
                            <input type="number" id="calcDays" class="form-control" 
                                   min="1" max="365" value="30">
                        </div>
                    </div>
                    
                    <button class="btn btn-outline" id="calculateBtn">
                        <i class="fas fa-calculator"></i>
                        Calculate Profit
                    </button>
                </div>
                
                <div class="calculator-results" id="calculatorResults" style="display: none;">
                    <h4>Projected Earnings</h4>
                    <div class="results-grid">
                        <div class="result-item">
                            <div class="result-label">Daily Profit</div>
                            <div class="result-value" id="dailyProfit">$0.00</div>
                        </div>
                        <div class="result-item">
                            <div class="result-label">Total Profit</div>
                            <div class="result-value" id="totalProfit">$0.00</div>
                        </div>
                        <div class="result-item">
                            <div class="result-label">Total Return</div>
                            <div class="result-value" id="totalReturn">$0.00</div>
                        </div>
                        <div class="result-item">
                            <div class="result-label">ROI</div>
                            <div class="result-value" id="roiPercentage">0%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Active Investments -->
        <% if (user && userInvestments && userInvestments.length > 0) { %>
            <div class="active-investments-section">
                <div class="section-card">
                    <div class="section-header">
                        <h2>Your Active Investments</h2>
                        <p>Track your current investments and earnings</p>
                    </div>
                    
                    <div class="investments-list">
                        <% userInvestments.forEach(investment => { %>
                            <div class="investment-item">
                                <div class="investment-icon">
                                    <i class="fas fa-chart-pie"></i>
                                </div>
                                
                                <div class="investment-details">
                                    <div class="investment-name"><%= investment.planName %></div>
                                    <div class="investment-meta">
                                        <span class="investment-amount">$<%= investment.amount %></span>
                                        <span class="investment-date">
                                            Started <%= new Date(investment.startDate).toLocaleDateString() %>
                                        </span>
                                    </div>
                                </div>
                                
                                <div class="investment-earnings">
                                    <div class="earnings-amount">+$<%= investment.totalEarned %></div>
                                    <div class="earnings-label">Total Earned</div>
                                </div>
                                
                                <div class="investment-status <%= investment.status %>">
                                    <%= investment.status %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Investment FAQ -->
        <div class="faq-section">
            <div class="section-card">
                <div class="section-header">
                    <h2>Frequently Asked Questions</h2>
                </div>
                
                <div class="faq-list">
                    <div class="faq-item">
                        <div class="faq-question">
                            <h4>How do the investment plans work?</h4>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Our investment plans work by pooling funds from investors and using advanced trading algorithms to generate daily profits. Each plan has a fixed duration and daily profit percentage.</p>
                        </div>
                    </div>
                    
                    <div class="faq-item">
                        <div class="faq-question">
                            <h4>When are profits distributed?</h4>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Profits are calculated and distributed daily at 00:00 UTC. You can see your earnings updated in your wallet balance every morning.</p>
                        </div>
                    </div>
                    
                    <div class="faq-item">
                        <div class="faq-question">
                            <h4>Can I withdraw my investment early?</h4>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Investments are locked for the duration of the plan. Early withdrawal is not available to ensure consistent returns for all investors.</p>
                        </div>
                    </div>
                    
                    <div class="faq-item">
                        <div class="faq-question">
                            <h4>Is there any risk involved?</h4>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>While we employ advanced risk management strategies, all investments carry some degree of risk. However, our track record shows consistent positive returns across all investment plans.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Investment Modal -->
<div class="modal" id="investmentModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Confirm Investment</h3>
            <button class="modal-close">&times;</button>
        </div>
        
        <div class="modal-body">
            <div class="investment-summary">
                <div class="summary-item">
                    <span>Plan:</span>
                    <span id="modalPlanName">-</span>
                </div>
                <div class="summary-item">
                    <span>Amount:</span>
                    <span id="modalPlanAmount">$0.00</span>
                </div>
                <div class="summary-item">
                    <span>Daily Profit:</span>
                    <span id="modalDailyProfit">0%</span>
                </div>
                <div class="summary-item">
                    <span>Duration:</span>
                    <span>30 Days</span>
                </div>
                <div class="summary-item total">
                    <span>Estimated Total Profit:</span>
                    <span id="modalTotalProfit">$0.00</span>
                </div>
            </div>
            
            <form id="investmentForm">
                <input type="hidden" id="selectedPlanId" name="planId">
                <input type="hidden" id="selectedAmount" name="amount">
                
                <div class="form-group">
                    <label for="investmentWallet">Select Funding Wallet</label>
                    <select id="investmentWallet" name="wallet" class="form-control" required>
                        <option value="">Select wallet</option>
                        <option value="usdt">USDT Wallet ($<%= walletBalance.usdt.toFixed(2) %> available)</option>
                        <option value="btc">BTC Wallet (<%= walletBalance.btc.toFixed(8) %> BTC available)</option>
                        <option value="eth">ETH Wallet (<%= walletBalance.eth.toFixed(6) %> ETH available)</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="checkbox">
                        <input type="checkbox" name="agreeTerms" required>
                        <span class="checkmark"></span>
                        I agree to the <a href="/terms" target="_blank">Investment Terms</a> and understand the risks involved
                    </label>
                </div>
            </form>
        </div>
        
        <div class="modal-footer">
            <button class="btn btn-outline" id="cancelInvestment">Cancel</button>
            <button class="btn btn-primary" id="confirmInvestment">
                <i class="fas fa-check"></i>
                Confirm Investment
            </button>
        </div>
    </div>
</div>

<style>
