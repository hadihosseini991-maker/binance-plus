# Binance Plus Environment Configuration
# Copy this file to .env and update the values

# Server Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/binanceplus

# Session Security
SESSION_SECRET=your-super-secure-session-secret-key-change-in-production

# Email Service (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Application URL
APP_URL=http://localhost:3000

# Security
JWT_SECRET=your-jwt-secret-key
CRYPTO_SECRET=your-encryption-secret-key

# API Keys (Optional)
COINGECKO_API_URL=https://api.coingecko.com/api/v3